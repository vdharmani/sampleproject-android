<?xml version="1.0" encoding="utf-8"?>
<!--
    Backup / device-transfer rules for Android 12 and above
    (android:dataExtractionRules). Backups stay enabled — only secrets are
    excluded, from both cloud backup and direct device-to-device transfer.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" path="datastore/auth_tokens.preferences_pb" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="datastore/auth_tokens.preferences_pb" />
    </device-transfer>
</data-extraction-rules>
