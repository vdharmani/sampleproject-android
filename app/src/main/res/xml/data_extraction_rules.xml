<?xml version="1.0" encoding="utf-8"?>
<!--
    Device-transfer rules for Android 12+ (android:dataExtractionRules).

    Cloud backup is disabled outright via android:allowBackup="false". The
    <device-transfer> block still matters — phone-to-phone migration is NOT
    gated by allowBackup — so the encrypted auth-token store is excluded
    there. The <cloud-backup> block is kept as belt-and-braces should backup
    ever be re-enabled.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" path="datastore/auth_tokens.preferences_pb" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="datastore/auth_tokens.preferences_pb" />
    </device-transfer>
</data-extraction-rules>
