root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.{kt,kts}]
max_line_length = 120
ktlint_code_style = android_studio
ktlint_standard_no-wildcard-imports = enabled
# @Composable functions are PascalCase by Compose convention — exempt them
# from the camelCase function-naming rule.
ktlint_function_naming_ignore_when_annotated_with = Composable

[*.{yml,yaml,xml,json}]
indent_size = 2
